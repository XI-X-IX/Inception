# ─────────────────────────────────────────────
# Copie ce fichier en .env et remplis les valeurs
# cp .env.example .env
# ─────────────────────────────────────────────

# Ton domaine (doit pointer vers ta VM dans /etc/hosts)
DOMAIN_NAME=aledos-s.42.fr

# ── WordPress ─────────────────────────────────
# URL publique du site
WP_URL=https://aledos-s.42.fr

# Titre affiché sur le site WordPress
WP_TITLE=Inception

# Compte administrateur WordPress
# ATTENTION : ne doit pas contenir "admin" ou "administrator"
WP_ADMIN_USER=aledos
WP_ADMIN_EMAIL=aledos-s@student.42.fr

# Second utilisateur (rôle éditeur)
WP_SECOND_USER=student
WP_SECOND_EMAIL=student@student.42.fr

# ── MariaDB ───────────────────────────────────
# Nom de la base de données WordPress
MYSQL_DATABASE=wordpress

# Utilisateur MariaDB pour WordPress
MYSQL_USER=wpuser

# ── FTP ───────────────────────────────────────
# Nom d'utilisateur FTP (le mot de passe est dans secrets/ftp_password.txt)
FTP_USER=ftpuser

# ── Grafana ───────────────────────────────────
# Mot de passe du compte admin Grafana
# (accessible sur https://aledos-s.42.fr/grafana/)
GF_ADMIN_PASSWORD=changeme